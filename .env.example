# Copy to `.env` and fill in. Vite only exposes env vars prefixed with VITE_.

# Required for WalletConnect (and RainbowKit’s QR / mobile flow).
# Create a project: https://cloud.reown.com/ (WalletConnect) — then paste the Project ID here.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: custom RPCs (faster or higher limits than the default public nodes).
# Base Sepolia (testnet) — used by default; leave empty to use the built-in public RPC.
VITE_BASE_SEPOLIA_RPC_URL=
# Base mainnet
VITE_BASE_MAINNET_RPC_URL=

# x402: full URL for a paid POST. Example: https://app.keeperhub.com/api/mcp/workflows/microtip/call
# Leave empty in `npm run dev` to use the same-origin /keeperhub proxy (see vite.config.ts) — needed so the
# retry after wallet signing (PAYMENT-SIGNATURE) is not blocked by cross-origin CORS in the browser.
VITE_X402_TEST_URL=

# Local open-agent returns HTTP 400 `{ code: "PAYMENT_REQUIRED" }` without a PAYMENT-REQUIRED challenge:
# set the payout address (and optional amount in USDC min units) so the browser can synthesize an x402 v2
# challenge and run @x402/fetch. Values must match what your server verifies.
# VITE_LOCAL_OPEN_AGENT_X402_PAY_TO=
# VITE_LOCAL_OPEN_AGENT_X402_AMOUNT=

# Paid workflow gateway (`GatewayExecutePanel`): POST /workflows/:id/execute, GET /workflows, GET /health.
# Reference implementation: sibling repo `lendpay-backend` — set **X402_RECEIVING_ADDRESS** there so missing
# X-PAYMENT responses include an x402 v2 challenge (USDC amount from JSON body `amount`, within each workflow’s min/max).
# Leave unset in dev to use same-origin `/gateway` (Vite proxy → localhost:3001).
# VITE_GATEWAY_BASE_URL=http://localhost:3001
# Optional default bearer token for local testing (still editable in the UI).
# VITE_GATEWAY_API_TOKEN=
