# Copy to `.env` and fill in. Vite only exposes env vars prefixed with VITE_.

# Required for WalletConnect (and RainbowKit’s QR / mobile flow).
# Create a project: https://cloud.reown.com/ (WalletConnect) — then paste the Project ID here.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: custom RPCs (faster or higher limits than the default public nodes).
# Base Sepolia (testnet) — used by default; leave empty to use the built-in public RPC.
VITE_BASE_SEPOLIA_RPC_URL=
# Base mainnet
VITE_BASE_MAINNET_RPC_URL=

# x402: full URL for a paid POST in production / preview (when not using the dev proxy).
# Example: https://app.keeperhub.com/api/mcp/workflows/microtip/call
# Leave empty in `npm run dev` to use the Vite /keeperhub proxy (see vite.config.ts).
VITE_X402_TEST_URL=
